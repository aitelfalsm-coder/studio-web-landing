RewriteEngine On

# Forcer HTTPS + supprimer www → redirection 301 vers https://studioweb.ma
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} ^www\. [NC]
RewriteCond %{HTTP_HOST} ^(?:www\.)?(.+)$ [NC]
RewriteRule ^ https://studioweb.ma%{REQUEST_URI} [R=301,L]

# Supprimer tout header X-Robots-Tag noindex potentiellement injecté par l'hébergeur
<IfModule mod_headers.c>
  Header unset X-Robots-Tag
  Header always set X-Robots-Tag "index, follow"
</IfModule>
